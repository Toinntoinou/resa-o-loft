# ─── Base de données ───────────────────────────────────────────────
# En local : SQLite (aucune installation requise)
DATABASE_URL="file:./dev.db"
# En production (Vercel/Neon) : remplacer par une URL Postgres, ex :
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# ─── Accès administrateur ──────────────────────────────────────────
# Mot de passe pour se connecter à /admin. À CHANGER.
ADMIN_PASSWORD="loft2026"
# Clé secrète pour signer la session admin (chaîne aléatoire longue). À CHANGER.
SESSION_SECRET="remplacez-moi-par-une-longue-chaine-aleatoire"

# ─── Emails ─────────────────────────────────────────────────────────
# Deux façons d'envoyer (le SMTP est prioritaire si les deux sont remplis) :
#
# OPTION A — Votre propre boîte mail (SMTP), ex. leloft@naama.work.
# Utiliser un MOT DE PASSE D'APPLICATION (jamais votre vrai mot de passe).
#   Microsoft 365 : SMTP_HOST="smtp.office365.com", port 587
#   Google Workspace : SMTP_HOST="smtp.gmail.com", port 587
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""   # ex. leloft@naama.work
SMTP_PASS=""   # mot de passe d'application

# OPTION B — Resend (service d'envoi) : clé API depuis https://resend.com
RESEND_API_KEY=""

# Expéditeur affiché. Avec SMTP, mettre l'adresse de la boîte (sinon rejets).
EMAIL_FROM="Le Loft <leloft@naama.work>"
# Adresse qui reçoit la notification de chaque nouvelle réservation (optionnel).
EMAIL_ADMIN_NOTIFY=""

# ─── Identité de l'espace (affiché sur le site) ────────────────────
NEXT_PUBLIC_SITE_NAME="Le Loft"
NEXT_PUBLIC_SITE_TAGLINE="Espace de coworking"

# ─── Mentions légales / RGPD (page Politique de confidentialité) ───
LEGAL_ENTITY="SAS CROCOW"
LEGAL_ADDRESS=""              # adresse du siège (ex : "12 rue X, 75000 Paris")
PRIVACY_EMAIL="contact@votredomaine.fr"  # contact pour les demandes RGPD
RETENTION_MONTHS="24"         # suppression auto des réservations après N mois

# ─── Purge automatique (Vercel Cron) ───────────────────────────────
# Secret protégeant l'endpoint de purge. Générer une longue chaîne aléatoire.
CRON_SECRET=""
